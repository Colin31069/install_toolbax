<Window x:Class="InstallToolbox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:InstallToolbox.ViewModels"
        xmlns:models="clr-namespace:InstallToolbox.Models"
        mc:Ignorable="d"
        Title="Windows 軟體安裝管理工具" Height="600" Width="900" 
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <!-- 基礎資源與轉換器 (為了狀態顏色等) -->
    <Window.Resources>
        <!-- 未來可以加 Convertors，暫不為了 MVP 複雜化 -->
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- 頂部標題與 Logo -->
        <Border Background="#2B579A" Grid.Row="0" Grid.ColumnSpan="2" Padding="15">
            <TextBlock Text="Windows 軟體自動部署工具 - 圖吧風格 MVP" Foreground="White" FontSize="18" FontWeight="Bold"/>
        </Border>

        <!-- 左側導航 (分類) -->
        <Border Grid.Row="1" Grid.Column="0" Background="#F0F0F0" BorderBrush="#DDDDDD" BorderThickness="0,0,1,0">
            <ListBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" 
                     Background="Transparent" BorderThickness="0" Margin="10">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" FontSize="16" Padding="5,10"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- 右側軟體清單 -->
        <DataGrid Grid.Row="1" Grid.Column="1" 
                  ItemsSource="{Binding SelectedCategory.Apps}" 
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#EEEEEE" BorderThickness="0">
            <DataGrid.Columns>
                <!-- 勾選框 -->
                <DataGridTemplateColumn Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <!-- 名稱與描述 -->
                <DataGridTemplateColumn Header="應用程式" Width="250">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding Description}" Foreground="Gray" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 狀態 -->
                <DataGridTextColumn Header="狀態" Binding="{Binding Status}" Width="100" IsReadOnly="True" />
                
                <!-- 單項進度 -->
                <DataGridTemplateColumn Header="進度" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ProgressBar Value="{Binding Progress}" Maximum="100" Height="15" Margin="5"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 錯誤訊息 -->
                <DataGridTextColumn Header="訊息" Binding="{Binding ErrorMessage}" Width="*" IsReadOnly="True" Foreground="Red" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- 底部控制列 -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#FAFAFA" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding GlobalStatusMessage}" FontWeight="Bold"/>
                    <ProgressBar Value="{Binding GlobalProgress}" Maximum="100" Height="5" Margin="0,5,20,0"
                                 Width="400" HorizontalAlignment="Left" />
                </StackPanel>

                <Button Grid.Column="2" Content="開始安裝勾選項目" Command="{Binding StartBatchInstallCommand}"
                        Width="150" Height="35" Background="#2B579A" Foreground="White" FontWeight="Bold" 
                        IsEnabled="{Binding IsNotInstalling}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
