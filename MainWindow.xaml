<ui:FluentWindow x:Class="InstallToolbox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:viewmodels="clr-namespace:InstallToolbox.ViewModels"
        xmlns:models="clr-namespace:InstallToolbox.Models"
        xmlns:converters="clr-namespace:InstallToolbox.Converters"
        mc:Ignorable="d"
        Title="Windows 軟體安裝管理工具" Height="650" Width="950" 
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        ExtendsContentIntoTitleBar="True">
    <ui:FluentWindow.DataContext>
        <viewmodels:MainViewModel />
    </ui:FluentWindow.DataContext>

    <!-- 半透明玻璃卡片樣式 -->
    <ui:FluentWindow.Resources>
        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.1" />
                </Setter.Value>
            </Setter>
        </Style>
        <converters:IconResolverConverter x:Key="IconResolver"/>
    </ui:FluentWindow.Resources>

    <!-- 主容器 -->
    <Grid>
        <!-- 玻璃感背景層次的氛圍色塊 -->
        <Ellipse Width="450" Height="450" Fill="#200078D7" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-100,-100,0" IsHitTestVisible="False">
            <Ellipse.Effect><BlurEffect Radius="120" /></Ellipse.Effect>
        </Ellipse>
        <Ellipse Width="550" Height="550" Fill="#1A4CAF50" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-150,0,0,-150" IsHitTestVisible="False">
            <Ellipse.Effect><BlurEffect Radius="150" /></Ellipse.Effect>
        </Ellipse>

        <!-- 介面內容區 -->
        <Grid>
            <Grid.LayoutTransform>
                <ScaleTransform ScaleX="{Binding UiScaleRate}" ScaleY="{Binding UiScaleRate}"/>
            </Grid.LayoutTransform>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- WPF-UI 標題欄 (TitleBar) -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2">
            <ui:TitleBar Title="Windows 軟體自動部署工具 (分組模式)" />
        </Grid>

        <!-- 左側導航 (Groups) -->
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource GlassCardStyle}" Margin="10,0,5,10">
            <ListBox ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroup}" 
                     Background="Transparent" BorderThickness="0" Margin="5">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="Margin" Value="0,5"/>
                                <Setter Property="Padding" Value="0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <StackPanel Margin="5,10" x:Name="NormalContent">
                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Border x:Name="SeparatorContent" Visibility="Collapsed" Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="5,2"/>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                <Setter TargetName="NormalContent" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="SeparatorContent" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- 右側主要區域 -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- 上方 Presets 區域 -->
            <Border Grid.Row="0" Style="{StaticResource GlassCardStyle}" Margin="5,0,10,10" Padding="15,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="快速預設清單：" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                            <ToggleButton x:Name="ExpandToggleBtn" Content="顯示全部" Margin="10,0" Padding="8,4" />
                            <TextBlock Text="(展開後可拖曳按鈕自訂排序)" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11" />
                        </StackPanel>
                        
                        <ScrollViewer MaxHeight="45" VerticalScrollBarVisibility="Auto">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=ExpandToggleBtn}" Value="True">
                                            <Setter Property="MaxHeight" Value="200"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>
                            <ItemsControl ItemsSource="{Binding Presets}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Button Margin="5,5"
                                                   Content="{Binding Name}"
                                                   Appearance="Primary"
                                                   AllowDrop="True"
                                                   Click="Preset_Click"
                                                   PreviewMouseLeftButtonDown="Preset_PreviewMouseLeftButtonDown"
                                                   PreviewMouseLeftButtonUp="Preset_PreviewMouseLeftButtonUp"
                                                   PreviewMouseMove="Preset_PreviewMouseMove"
                                                   DragOver="Preset_DragOver"
                                                   Drop="Preset_Drop" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- 右側操作區：設定與主題切換 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <ui:Button Appearance="Transparent" Command="{Binding OpenSettingsCommand}" ToolTip="設定" Margin="0,0,5,0">
                            <ui:SymbolIcon Symbol="Settings24" FontSize="18" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </ui:Button>
                        <ui:Button Appearance="Transparent" Command="{Binding ToggleThemeCommand}" ToolTip="切換系統明暗佈景">
                            <ui:SymbolIcon Symbol="{Binding ThemeIcon}" FontSize="18" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 下方 Sections 分頁區 -->
            <TabControl Grid.Row="1" ItemsSource="{Binding SelectedGroup.Sections}" SelectedItem="{Binding SelectedSection, Mode=TwoWay}" Margin="10" Background="Transparent" BorderThickness="0">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.SelectedGroup.Sections.Count, RelativeSource={RelativeSource AncestorType=Window}}" Value="1">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TabControl.ItemContainerStyle>
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" FontSize="14" Padding="10,5"/>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <Grid>
                            <!-- Section 底下的 App 清單 DataGrid -->
                            <DataGrid ItemsSource="{Binding Apps}" 
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource ControlStrokeColorDefaultBrush}" 
                                      BorderThickness="0"
                                      Background="Transparent" RowBackground="Transparent" RowHeight="{Binding DataContext.ListDensityLineHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                                <DataGrid.Columns>
                                <!-- 勾選框 -->
                                <DataGridTemplateColumn Width="64">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0">
                                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- 名稱與描述 -->
                                <DataGridTemplateColumn Header="應用程式" Width="250">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="5">
                                                <Image Source="{Binding IconPath, Converter={StaticResource IconResolver}}" Width="32" Height="32" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                                    <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 狀態 -->
                                <DataGridTextColumn Header="狀態" Binding="{Binding Status}" Width="100" IsReadOnly="True" />
                                
                                <!-- 單項進度 -->
                                <DataGridTemplateColumn Header="進度" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ProgressBar Value="{Binding Progress}" Maximum="100" Height="15" Margin="5"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 錯誤訊息 -->
                                <DataGridTextColumn Header="訊息" Binding="{Binding ErrorMessage}" Width="*" IsReadOnly="True" Foreground="Red" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- 空狀態提示：當該 Section 的 Apps 為 0 時顯示 -->
                        <TextBlock Text="此分類目前沒有可顯示的 App" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Apps.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>

            <!-- 群組或 Section 為 Null 時的空狀態提示 -->
            <TextBlock Grid.Row="1" 
                       Text="請於左側選擇群組或分類不存在" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center" 
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                       FontSize="18"
                       FontWeight="Bold">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- 底部控制列 -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource GlassCardStyle}" Margin="10,0,10,10">
            <Grid Margin="20,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding GlobalStatusMessage}" FontWeight="Bold"/>
                    <ProgressBar Value="{Binding GlobalProgress}" Maximum="100" Height="5" Margin="0,5,20,0"
                                  Width="400" HorizontalAlignment="Left" />
                </StackPanel>

                <ui:Button Grid.Column="1" Content="取消所有選取" Command="{Binding ClearAllSelectionsCommand}"
                        Width="130" Height="35" Appearance="Secondary" Margin="0,0,10,0"
                        IsEnabled="{Binding IsNotInstalling}"/>

                <ui:Button Grid.Column="2" Content="開始安裝勾選項目" Command="{Binding StartBatchInstallCommand}"
                        Width="150" Height="35" Appearance="Primary"  
                        IsEnabled="{Binding IsNotInstalling}"/>
            </Grid>
        </Border>
    </Grid>
</Grid>
</ui:FluentWindow>
