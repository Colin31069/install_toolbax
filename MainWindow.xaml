<Window x:Class="InstallToolbox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:InstallToolbox.ViewModels"
        xmlns:models="clr-namespace:InstallToolbox.Models"
        mc:Ignorable="d"
        Title="Windows 軟體安裝管理工具" Height="650" Width="950" 
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- 頂部標題與 Logo -->
        <Border Background="#2B579A" Grid.Row="0" Grid.ColumnSpan="2" Padding="15">
            <TextBlock Text="Windows 軟體自動部署工具 (分組模式)" Foreground="White" FontSize="18" FontWeight="Bold"/>
        </Border>

        <!-- 左側導航 (Groups) -->
        <Border Grid.Row="1" Grid.Column="0" Background="#F0F0F0" BorderBrush="#DDDDDD" BorderThickness="0,0,1,0">
            <ListBox ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroup}" 
                     Background="Transparent" BorderThickness="0" Margin="10">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5,10">
                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="Gray" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- 右側主要區域 -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- 上方 Presets 區域 -->
            <Border Grid.Row="0" Margin="10,10,10,0" Padding="10" Background="#EFEFEF" CornerRadius="5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="快速預設清單：" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                    <ItemsControl ItemsSource="{Binding Presets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Name}" 
                                        Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                        CommandParameter="{Binding}" 
                                        Padding="10,5" Margin="5,0"
                                        Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 下方 Sections 分頁區 -->
            <TabControl Grid.Row="1" ItemsSource="{Binding SelectedGroup.Sections}" SelectedIndex="{Binding SelectedSectionIndex}" Margin="10" Background="White">
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" FontSize="14" Padding="10,5"/>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <!-- Section 底下的 App 清單 DataGrid -->
                        <DataGrid ItemsSource="{Binding Apps}" 
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#EEEEEE" BorderThickness="0" Background="White" RowHeight="45">
                            <DataGrid.Columns>
                                <!-- 勾選框 -->
                                <DataGridTemplateColumn Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- 名稱與描述 -->
                                <DataGridTemplateColumn Header="應用程式" Width="250">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="5">
                                                <Image Source="{Binding IconPath, TargetNullValue='', FallbackValue=''}" Width="32" Height="32" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                                    <TextBlock Text="{Binding Description}" Foreground="Gray" FontSize="12" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 狀態 -->
                                <DataGridTextColumn Header="狀態" Binding="{Binding Status}" Width="100" IsReadOnly="True" />
                                
                                <!-- 單項進度 -->
                                <DataGridTemplateColumn Header="進度" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ProgressBar Value="{Binding Progress}" Maximum="100" Height="15" Margin="5"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 錯誤訊息 -->
                                <DataGridTextColumn Header="訊息" Binding="{Binding ErrorMessage}" Width="*" IsReadOnly="True" Foreground="Red" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </Grid>

        <!-- 底部控制列 -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#FAFAFA" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding GlobalStatusMessage}" FontWeight="Bold"/>
                    <ProgressBar Value="{Binding GlobalProgress}" Maximum="100" Height="5" Margin="0,5,20,0"
                                 Width="400" HorizontalAlignment="Left" />
                </StackPanel>

                <Button Grid.Column="2" Content="開始安裝勾選項目" Command="{Binding StartBatchInstallCommand}"
                        Width="150" Height="35" Background="#2B579A" Foreground="White" FontWeight="Bold" 
                        IsEnabled="{Binding IsNotInstalling}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
